# Core application settings
APP_ENV=dev
APP_ENV_DOCKER=docker
API_V1_PREFIX=/api/v1
API_KEY=

# Postgres container settings (docker-compose db service)
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
# Used by scripts/docker/20-init-test-db.sh mounted into db container.
POSTGRES_TEST_DB=rag_test
POSTGRES_HOST_PORT=55432

# Host-side DB URLs (used by Alembic + pytest when run from your shell)
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:55432/rag
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:55432/rag_test

# Container-side URLs (used by api/worker inside docker compose network)
DOCKER_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/rag
DOCKER_OLLAMA_BASE_URL=http://ollama:11434

# Host-side model provider URL
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model/runtime tuning
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_CHARS=200
MAX_DOC_CHARS=200000
RETRIEVE_TOP_K=5
REQUEST_TIMEOUT_S=120
